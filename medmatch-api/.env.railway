# =============================================================
# MedMatch API — Railway Environment Variables
# คัดลอกค่าเหล่านี้ไปวางใน Railway > Service > Variables
# =============================================================

# --- Database (Railway PostgreSQL Plugin ตั้งให้อัตโนมัติ) ---
# DATABASE_URL  ← Railway จะฉีดตัวแปรนี้ให้เองเมื่อ Add PostgreSQL Plugin

# --- JWT (สร้างด้วย: openssl rand -hex 64) ---
JWT_SECRET=REPLACE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption AES-256 (สร้างด้วย: openssl rand -hex 32) ---
ENCRYPTION_KEY=REPLACE_ME_64_HEX_CHARS
ENCRYPTION_KEY_VERSION=1

# --- CORS (ใส่ Railway domain + Expo URL) ---
# ตัวอย่าง: https://medmatch-api.up.railway.app,exp://192.168.x.x:8081
CORS_ORIGINS=*

# --- Node ---
NODE_ENV=production
APP_ENV=production
# PORT ไม่ต้องตั้ง — Railway inject ให้อัตโนมัติ

# --- Firebase (ถ้าใช้ push notifications) ---
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Mapbox ---
MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# --- Object Storage (เลือก 1 แบบ) ---
# แบบ Oracle OCI:
OCI_NAMESPACE=
OCI_BUCKET_NAME=medmatch-files
OCI_REGION=ap-singapore-1
OCI_ACCESS_KEY=
OCI_SECRET_KEY=

# แบบ AWS S3 / Cloudflare R2:
# S3_ENDPOINT=https://...r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=medmatch-files
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- OpenAI (slip verification) ---
OPENAI_API_KEY=sk-...

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100
