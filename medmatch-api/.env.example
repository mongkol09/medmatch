# MedMatch API — Environment Variables
# ===================================
# SECURITY: Never commit .env to git

# --- Database ---
DATABASE_URL="postgresql://medmatch:changeme@localhost:5432/medmatch?schema=public&sslmode=require"

# --- JWT ---
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Encryption (AES-256-GCM) ---
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_64_HEX_CHARS_FOR_AES_256"
ENCRYPTION_KEY_VERSION="1"

# --- Firebase ---
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# --- Mapbox ---
MAPBOX_ACCESS_TOKEN=""

# --- Google Places (optional supplement) ---
GOOGLE_PLACES_API_KEY=""

# --- Oracle Object Storage ---
OCI_NAMESPACE=""
OCI_BUCKET_NAME="medmatch-files"
OCI_REGION="ap-singapore-1"
OCI_ACCESS_KEY=""
OCI_SECRET_KEY=""

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- App ---
APP_PORT=3000
APP_ENV="development"
CORS_ORIGINS="http://localhost:8081,http://localhost:3001"

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Sentry ---
SENTRY_DSN=""
